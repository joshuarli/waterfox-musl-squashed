#!/usr/bin/env bash
set -euo pipefail

objdir=${MOZ_OBJDIR:-/cache/obj-aarch64-alpine-linux-musl}
config=$objdir/config.status
log=$objdir/config.log
compile_commands=$objdir/clangd/compile_commands.json
mode=${WFX_CONFIG_MODE:-debug}
expect_webdriver=${WFX_CONFIG_WEBDRIVER:-0}
expect_widget_toolkit=${WFX_CONFIG_WIDGET_TOOLKIT:-}
expect_mimalloc_prefix=${WFX_CONFIG_MIMALLOC_PREFIX:-/opt/wfx/build-deps/mimalloc}
expect_static_gcc_runtime=${WFX_EXPECT_STATIC_GCC_RUNTIME:-0}
expect_static_font_stack=${WFX_EXPECT_STATIC_FONT_STACK:-0}
expect_static_wayland_stack=${WFX_EXPECT_STATIC_WAYLAND_STACK:-0}

fail() {
  printf 'wfx config check failed: %s\n' "$*" >&2
  exit 1
}

require_file() {
  [ -f "$1" ] || fail "missing $1"
}

require_config() {
  local key=$1 value=$2
  grep -Eq "^[[:space:]]*'$key': '$value'," "$config" ||
    fail "expected $key=$value in config.status"
}

require_config_empty() {
  local key=$1
  grep -Eq "^[[:space:]]*'$key': ''," "$config" ||
    fail "expected $key to be empty in config.status"
}

reject_config_key() {
  local key=$1
  if grep -Eq "^[[:space:]]*'$key':" "$config"; then
    fail "unexpected $key in config.status"
  fi
}

require_file "$config"
require_file "$log"

require_config MOZ_WAYLAND 1
case "$mode" in
  debug)
    require_config MOZ_DEBUG 1
    reject_config_key MOZ_OPTIMIZE
    require_config MOZ_AUDIO_BACKENDS_NONE 1
    reject_config_key MOZ_ALSA
    ;;
  release)
    reject_config_key MOZ_DEBUG
    require_config MOZ_OPTIMIZE 1
    require_config MOZ_AUDIO_BACKENDS_NONE 1
    reject_config_key MOZ_ALSA
    ;;
  alsa-debug)
    require_config MOZ_DEBUG 1
    reject_config_key MOZ_OPTIMIZE
    require_config MOZ_ALSA 1
    reject_config_key MOZ_AUDIO_BACKENDS_NONE
    ;;
  *)
    fail "unknown WFX_CONFIG_MODE=$mode; expected debug, release, or alsa-debug"
    ;;
esac
require_config MOZ_MIMALLOC_REPLACE 1
require_config WFX_MIMALLOC_PREFIX "$expect_mimalloc_prefix"
require_config MOZ_LIBCLANG_PATH /usr/lib/llvm22/lib

if [ -n "$expect_widget_toolkit" ]; then
  require_config MOZ_WIDGET_TOOLKIT "$expect_widget_toolkit"
fi

if [ "${WFX_EXPECT_FOLD_LIBS:-0}" = 1 ]; then
  require_config MOZ_FOLD_LIBS 1
fi

case "$expect_static_gcc_runtime" in
  1)
    grep -Eq -- "-static-libstdc\\+\\+" "$config" ||
      fail "static libstdc++ linker flag was not configured"
    grep -Eq -- "-static-libgcc" "$config" ||
      fail "static libgcc linker flag was not configured"
    require_config_empty MOZ_FOLD_LIBS
    ;;
  0)
    ;;
  *)
    fail "unknown WFX_EXPECT_STATIC_GCC_RUNTIME=$expect_static_gcc_runtime; expected 0 or 1"
    ;;
esac

case "$expect_static_font_stack" in
  1)
    require_config WFX_STATIC_FONT_PKG_CONFIG 1
    grep -Eq -- "build-deps/fontstack[^']*/lib" "$config" ||
      fail "font stack library path was not configured"
    awk '
      $0 ~ "'\''FT2_LIBS'\'':" { in_list = 1; saw = 1 }
      in_list && $0 ~ "'\''-lfontconfig'\''" { found = 1 }
      in_list && $0 ~ /\],/ { in_list = 0 }
      END { if (!saw || !found) exit 1 }
    ' "$config" ||
      fail "fontconfig was not included in FT2_LIBS"
    awk '
      $0 ~ "'\''_FONTCONFIG_LIBS'\'':" { in_list = 1; saw = 1 }
      in_list && $0 ~ "'\''-lfontconfig'\''" { found = 1 }
      in_list && $0 ~ /\],/ { in_list = 0 }
      END { if (!saw || !found) exit 1 }
    ' "$config" ||
      fail "static font pkg-config mode was not configured"
    ;;
  0)
    ;;
  *)
    fail "unknown WFX_EXPECT_STATIC_FONT_STACK=$expect_static_font_stack; expected 0 or 1"
    ;;
esac

case "$expect_static_wayland_stack" in
  1)
    require_config WFX_STATIC_WAYLAND_PKG_CONFIG 1
    grep -Eq -- "build-deps/waylandstack[^']*/lib" "$config" ||
      fail "Wayland stack library path was not configured"
    awk '
      $0 ~ "'\''MOZ_WAYLAND_LIBS'\'':" { in_list = 1; saw = 1 }
      in_list && $0 ~ "'\''-lwayland-client'\''" { found_wayland = 1 }
      in_list && $0 ~ "'\''-lxkbcommon'\''" { found_xkb = 1 }
      in_list && $0 ~ /\],/ { in_list = 0 }
      END { if (!saw || !found_wayland || !found_xkb) exit 1 }
    ' "$config" ||
      fail "static Wayland pkg-config mode was not configured"
    ;;
  0)
    ;;
  *)
    fail "unknown WFX_EXPECT_STATIC_WAYLAND_STACK=$expect_static_wayland_stack; expected 0 or 1"
    ;;
esac

reject_config_key MOZ_X11
reject_config_key MOZ_ENABLE_DBUS
reject_config_key NECKO_WIFI
reject_config_key ENABLE_SYSTEM_EXTENSION_DIRS
reject_config_key MOZ_AUTH_EXTENSION
reject_config_key MOZ_GECKO_PROFILER
reject_config_key MOZ_UNIVERSALCHARDET
reject_config_key MOZ_ZIPWRITER
reject_config_key MOZ_WEBRTC
reject_config_key MOZ_PULSEAUDIO
reject_config_key MOZ_SYSTEM_PIPEWIRE
reject_config_key MOZ_ENABLE_VAAPI
reject_config_key MOZ_ENABLE_V4L2
reject_config_key MOZ_SYNTH_SPEECHD
reject_config_key MOZ_WEBMIDI_MIDIR_IMPL
reject_config_key RELRHACK
reject_config_key USE_ELF_HACK

require_config_empty MOZ_WATERFOX_BLOCKER

case "$expect_webdriver" in
  1)
    require_config ENABLE_WEBDRIVER 1
    ;;
  0)
    reject_config_key ENABLE_WEBDRIVER
    ;;
  *)
    fail "unknown WFX_CONFIG_WEBDRIVER=$expect_webdriver; expected 0 or 1"
    ;;
esac

grep -Eq "^[[:space:]]*'CC_TYPE': CompilerType\\('clang'\\)," "$config" ||
  fail "target C compiler is not clang"
grep -Eq "^[[:space:]]*'HOST_CC_TYPE': CompilerType\\('clang'\\)," "$config" ||
  fail "host C compiler is not clang"
grep -Eq "^[[:space:]]*'_CC': '/usr/lib/llvm22/bin/clang-22'," "$config" ||
  fail "target C compiler is not clang-22"
grep -Eq "^[[:space:]]*'_CXX': '/usr/bin/clang\\+\\+-22'," "$config" ||
  fail "target C++ compiler is not clang++-22"
grep -Eq -- "-fuse-ld=mold" "$config" ||
  fail "mold linker was not selected"
grep -Eq -- "--pack-dyn-relocs=none" "$config" ||
  fail "packed relative relocations were not disabled"

case "$mode" in
  alsa-debug)
    if ! grep -Eq 'checking (MOZ_ALSA)|checking for alsa' "$log"; then
      fail "ALSA pkg-config check did not run"
    fi
    if grep -Eq 'checking (MOZ_PULSEAUDIO|MOZ_DBUS|MOZ_PIPEWIRE)|checking for (libpulse|dbus-1|libpipewire)' "$log"; then
      fail "PulseAudio, DBus, or PipeWire pkg-config check ran"
    fi
    ;;
  *)
    if grep -Eq 'checking (MOZ_ALSA|MOZ_PULSEAUDIO|MOZ_DBUS|MOZ_PIPEWIRE)|checking for (alsa|libpulse|dbus-1|libpipewire)' "$log"; then
      fail "audio, DBus, or PipeWire pkg-config check ran"
    fi
    ;;
esac

if [ -f "$compile_commands" ] &&
   grep -Eq '(^|[/" ])gcc([ "./-]|$)|(^|[/" ])g\+\+([ "./-]|$)' "$compile_commands"; then
  fail "compile_commands.json contains gcc or g++"
fi
