#!/usr/bin/env bash
set -euo pipefail

repo_root=${WFX_REPO_ROOT:-/work}
cache=${WFX_CACHE:-/cache}
objdir=${MOZ_OBJDIR:-/cache/obj-aarch64-alpine-linux-musl-minwayland}
dist=$cache/dist
stage=${WFX_STAGE_ROOT:-$dist/minwayland-root}
package=${WFX_WATERFOX_PACKAGE:-}
version=${WFX_STAGE1_VERSION:-}
date_utc=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
readelf=${READELF:-/usr/lib/llvm22/bin/llvm-readelf}
artifact_suffix=${WFX_STAGE_ARTIFACT_SUFFIX:-minwayland}
artifact_ext=${WFX_STAGE_ARTIFACT_EXT:-tar.xz}
mozconfig=${MOZCONFIG:-}

mkdir -p "$dist"

if [ -z "$package" ]; then
  package=$(find "$objdir/dist" -maxdepth 1 -type f \
    \( -name 'waterfox-*.linux-musl-*.tar.xz' -o \
       -name 'waterfox-*.linux-musl-*.tar.gz' \) | sort | tail -n 1)
fi

if [ -z "$package" ] || [ ! -f "$package" ]; then
  printf 'missing Waterfox package under %s/dist\n' "$objdir" >&2
  exit 1
fi

if [ -z "$version" ]; then
  version=$(basename "$package")
  version=${version%.tar.xz}
  version=${version%.tar.gz}
fi

rm -rf "$stage"
mkdir -p "$stage"

tar -xf "$package" -C "$stage" --strip-components=1

cat > "$stage/waterfox" <<'EOF'
#!/bin/sh
basedir=$(dirname "$0")
export MOZ_ENABLE_WAYLAND=1
export GDK_BACKEND=wayland
export NO_AT_BRIDGE=1
export MOZ_DISABLE_AUTO_SAFE_MODE=1
export MOZ_CRASHREPORTER_DISABLE=1
export LD_LIBRARY_PATH=$basedir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}
exec "$basedir/waterfox-bin" "$@"
EOF
chmod 0755 "$stage/waterfox"

strip_builtin_sidebar() {
  local omni json_tmp update_root
  omni=$stage/browser/omni.ja
  [ -f "$omni" ] || return 0

  update_root=$(mktemp -d)
  json_tmp=$update_root/chrome/browser/content/browser/built_in_addons.json
  mkdir -p "$(dirname "$json_tmp")"
  unzip -p "$omni" chrome/browser/content/browser/built_in_addons.json > "$json_tmp"
  python3 - "$json_tmp" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path) as f:
    data = json.load(f)

data["builtins"] = [
    addon for addon in data.get("builtins", [])
    if addon.get("addon_id") != "sidebar@waterfox.net"
]

with open(path, "w") as f:
    json.dump(data, f, separators=(",", ":"))
PY
  (cd "$update_root" && zip -q -u "$omni" chrome/browser/content/browser/built_in_addons.json)
  rm -rf "$update_root"
}

strip_builtin_sidebar

scan_report=$dist/$version.deps.txt
reject_report=$dist/$version.rejected-deps.txt
needed_report=$dist/$version.needed.txt
manifest=$dist/$version.manifest.txt
cli_smoke_report=$dist/$version.cli-smoke.txt
artifact=${WFX_STAGE_ARTIFACT:-$dist/$version.stage1-$artifact_suffix.$artifact_ext}
dep_summary=$(WFX_STAGE_ROOT="$stage" \
  WFX_WATERFOX_ALLOW_ALSA="${WFX_WATERFOX_ALLOW_ALSA:-${WFX_PACKAGE_ALSA:-0}}" \
  WFX_WATERFOX_DEPS_REPORT="$scan_report" \
  WFX_WATERFOX_DEPS_REJECT_REPORT="$reject_report" \
  WFX_WATERFOX_NEEDED_REPORT="$needed_report" \
  "$repo_root/docker/waterfox-musl/check-waterfox-deps")
elf_count=$(printf '%s\n' "$dep_summary" | awk -F= '$1 == "elf_count" { print $2 }')

if [ "${WFX_PACKAGE_CLI_SMOKE:-0}" = 1 ]; then
  WFX_STAGE_ROOT="$stage" \
    WFX_CLI_SMOKE_REPORT="$cli_smoke_report" \
    "$repo_root/docker/waterfox-musl/smoke-cli"
fi

case "$artifact_ext" in
  tar.xz)
    tar -C "$stage" -cJf "$artifact" .
    ;;
  tar.gz)
    tar -C "$stage" -cf - . | gzip -c > "$artifact"
    ;;
  *)
    printf 'unsupported WFX_STAGE_ARTIFACT_EXT=%s; expected tar.xz or tar.gz\n' "$artifact_ext" >&2
    exit 1
    ;;
esac

{
  printf 'artifact=%s\n' "$artifact"
  printf 'artifact_ext=%s\n' "$artifact_ext"
  printf 'source_package=%s\n' "$package"
  printf 'build_date_utc=%s\n' "$date_utc"
  printf 'waterfox_git_commit=%s\n' "$(git -C "$repo_root" rev-parse HEAD)"
  printf 'waterfox_git_dirty=%s\n' "$(git -C "$repo_root" status --short | wc -l | tr -d ' ')"
  printf 'alpine_release=%s\n' "$(cat /etc/alpine-release)"
  printf 'docker_image_id=%s\n' "$(cat /etc/hostname)"
  printf 'cc=%s\n' "$(command -v clang-22)"
  printf 'cxx=%s\n' "$(command -v clang++-22)"
  printf 'linker=%s\n' "$(command -v mold)"
  printf 'readelf=%s\n' "$(command -v "$readelf" 2>/dev/null || printf '%s' "$readelf")"
  printf 'mozconfig=%s\n' "$mozconfig"
  printf 'package_alsa=%s\n' "${WFX_PACKAGE_ALSA:-0}"
  printf 'elf_count=%s\n' "$elf_count"
  printf 'dependency_scan=%s\n' "$scan_report"
  printf 'needed_libraries=%s\n' "$needed_report"
  printf 'rejected_dependency_scan=%s\n' "$reject_report"
  if [ "${WFX_PACKAGE_CLI_SMOKE:-0}" = 1 ]; then
    printf 'cli_smoke=%s\n' "$cli_smoke_report"
  fi
  printf '\n[mozconfig]\n'
  if [ -n "$mozconfig" ] && [ -f "$mozconfig" ]; then
    cat "$mozconfig"
  fi
  printf '\n[apk]\n'
  apk info -vv | sort
  printf '\n[sources.lock]\n'
  cat "$repo_root/docker/waterfox-musl/sources.lock"
} > "$manifest"

printf 'Created stage 1 artifact: %s\n' "$artifact"
printf 'Created manifest: %s\n' "$manifest"
