#!/usr/bin/env bash
set -euo pipefail

repo_root=${WFX_REPO_ROOT:-/work}
cache=${WFX_CACHE:-/cache}
stage=${WFX_STAGE_ROOT:-$cache/dist/minwayland-root}
readelf=${READELF:-/usr/lib/llvm22/bin/llvm-readelf}
allowed=${WFX_WATERFOX_ALLOWED_NEEDED:-$repo_root/docker/waterfox-musl/waterfox-minwayland-allowed-needed.txt}
report=${WFX_WATERFOX_DEPS_REPORT:-$cache/dist/waterfox-final.deps.txt}
reject_report=${WFX_WATERFOX_DEPS_REJECT_REPORT:-$cache/dist/waterfox-final.rejected-deps.txt}
needed_report=${WFX_WATERFOX_NEEDED_REPORT:-$cache/dist/waterfox-final.needed.txt}
allow_alsa=${WFX_WATERFOX_ALLOW_ALSA:-0}
allow_gtk=${WFX_WATERFOX_ALLOW_GTK:-0}
hermetic=${WFX_WATERFOX_HERMETIC:-0}
allow_hardware=${WFX_WATERFOX_ALLOW_HARDWARE:-0}
hardware_allowed=${WFX_WATERFOX_HARDWARE_ALLOWED_NEEDED:-$repo_root/docker/waterfox-musl/waterfox-minwayland-hardware-allowed-needed.txt}
hardware_driver_regex=${WFX_WATERFOX_HARDWARE_DRIVER_REGEX:-'^virtio_gpu_dri\.so$'}
hermetic_baseline_regex=${WFX_WATERFOX_HERMETIC_BASELINE_REGEX:-'^libc\.musl-.*\.so\.1$'}
deny_regex='libX11|libX11-xcb|libxcb|libxcb-shm|libxcb-composite|libxcb-dri3|libxcb-ewmh|libxcb-icccm|libxcb-present|libxcb-randr|libxcb-render|libxcb-shape|libxcb-shm|libxcb-sync|libxcb-xfixes|libXcomposite|libXdamage|libXext|libXfixes|libXi|libXinerama|libXrandr|libXrender|libXcursor|libxkbfile|libXt|libSM|libICE|libGLX|libGL\.so|libvulkan|libpipewire|libpulse|libdbus|libnotify|libsecret|libspeechd|libcups|libhunspell|libmimalloc\.so'

if [ "$allow_alsa" != 1 ]; then
  deny_regex=$deny_regex'|libasound'
fi

if [ "$allow_gtk" != 1 ]; then
  deny_regex=$deny_regex'|libgtk|libgdk|libglib|libgio|libgobject|libpango|libatk|libatspi'
fi

fail() {
  printf 'wfx waterfox dependency check failed: %s\n' "$*" >&2
  exit 1
}

[ -x "$stage/waterfox" ] || fail "missing $stage/waterfox"
[ -f "$allowed" ] || fail "missing allowed dependency list $allowed"

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
actual=$tmp_dir/actual.txt
expected=$tmp_dir/expected.txt
optional=$tmp_dir/optional.txt
allowed_union=$tmp_dir/allowed-union.txt
providers=$tmp_dir/providers.txt
hermetic_allowed=$tmp_dir/hermetic-allowed.txt
unexpected=$tmp_dir/unexpected.txt
missing=$tmp_dir/missing.txt
unresolved=$tmp_dir/unresolved.txt

sed -n '/^[[:space:]]*#/d; /^[[:space:]]*$/d; s/[[:space:]]//g; p' "$allowed" | sort -u > "$expected"
: > "$optional"
case "$allow_hardware" in
  1)
    [ -f "$hardware_allowed" ] || fail "missing hardware dependency list $hardware_allowed"
    sed -n '/^[[:space:]]*#/d; /^[[:space:]]*$/d; s/[[:space:]]//g; p' "$hardware_allowed" | sort -u > "$optional"
    ;;
  0)
    ;;
  *)
    fail "unknown WFX_WATERFOX_ALLOW_HARDWARE=$allow_hardware; expected 0 or 1"
    ;;
esac
: > "$actual"
: > "$providers"
: > "$report"
: > "$reject_report"

elf_count=0
while IFS= read -r -d '' file; do
  base=$(basename "$file")
  if ! "$readelf" -h "$file" >/dev/null 2>&1; then
    continue
  fi

  elf_count=$((elf_count + 1))
  rel=${file#"$stage"/}
  {
    printf '### %s\n' "$rel"
    "$readelf" -d "$file" 2>/dev/null | sed -n '/NEEDED/p'
    printf '\n'
  } >> "$report"

  "$readelf" -d "$file" 2>/dev/null |
    sed -n 's/.*Shared library: \[\(.*\)\]/\1/p' >> "$actual"

  "$readelf" -d "$file" 2>/dev/null |
    sed -n 's/.*Library soname: \[\(.*\)\]/\1/p' >> "$providers"
  case "$base" in
    lib*.so|lib*.so.*)
      printf '%s\n' "$base" >> "$providers"
      ;;
  esac

  case "$rel" in
    */dri/*_dri.so|*/dri/*_drv_video.so)
      if [ "$allow_hardware" != 1 ] || ! [[ "$base" =~ $hardware_driver_regex ]]; then
        printf 'rejected Mesa/VA driver in %s\n' "$rel" >> "$reject_report"
      fi
      ;;
  esac

  if "$readelf" -d "$file" 2>/dev/null | grep -E "$deny_regex" >> "$reject_report"; then
    printf 'rejected dependency in %s\n' "$rel" >> "$reject_report"
  fi

  if "$readelf" -d "$file" 2>/dev/null | grep -E '0x000000000800002[345]' >> "$reject_report"; then
    printf 'rejected Android packed relative relocation tag in %s\n' "$rel" >> "$reject_report"
  fi
done < <(find "$stage" -type f -print0)

[ "$elf_count" -ne 0 ] || fail "no ELF files found in staged artifact"

sort -u "$actual" -o "$actual"
sort -u "$providers" -o "$providers"
if [ "$allow_alsa" = 1 ] && grep -Eq '^libasound\.so' "$actual"; then
  grep -E '^libasound\.so' "$actual" >> "$expected"
  sort -u "$expected" -o "$expected"
fi
cat "$expected" "$optional" | sort -u > "$allowed_union"
cp "$actual" "$needed_report"
comm -23 "$actual" "$allowed_union" > "$unexpected"
comm -13 "$actual" "$expected" > "$missing"

if [ -s "$unexpected" ]; then
  {
    printf 'unexpected NEEDED libraries:\n'
    sed 's/^/  /' "$unexpected"
  } >> "$reject_report"
fi

if [ -s "$missing" ]; then
  {
    printf 'missing expected NEEDED libraries:\n'
    sed 's/^/  /' "$missing"
  } >> "$reject_report"
fi

case "$hermetic" in
  1)
    cat "$providers" "$optional" | sort -u > "$hermetic_allowed"
    awk -v baseline="$hermetic_baseline_regex" '
      NR == FNR { providers[$0] = 1; next }
      $0 ~ baseline { next }
      !($0 in providers) { print }
    ' "$hermetic_allowed" "$actual" > "$unresolved"
    if [ -s "$unresolved" ]; then
      {
        printf 'non-hermetic NEEDED libraries:\n'
        sed 's/^/  /' "$unresolved"
      } >> "$reject_report"
    fi
    ;;
  0)
    ;;
  *)
    fail "unknown WFX_WATERFOX_HERMETIC=$hermetic; expected 0 or 1"
    ;;
esac

if [ -s "$reject_report" ]; then
  cat "$reject_report" >&2
  exit 1
fi

printf 'elf_count=%s\n' "$elf_count"
printf 'dependency_scan=%s\n' "$report"
printf 'needed_libraries=%s\n' "$needed_report"
