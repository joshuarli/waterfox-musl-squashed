#!/usr/bin/env bash
set -euo pipefail

repo_root=${WFX_REPO_ROOT:-/work}
cache=${WFX_CACHE:-/cache}
prefix=${WFX_SYSROOT:-/opt/wfx/sysroot}
lock=${WFX_SOURCES_LOCK:-$repo_root/docker/waterfox-musl/sources.lock}
sources=$cache/sources
build_root=$cache/build/sysroot
jobs=${JOBS:-$(nproc)}

mkdir -p "$sources" "$build_root" "$prefix" "$prefix/.wfx-stamps"

export PATH=$prefix/bin:/opt/wfx/python-tools/venv/bin:/usr/lib/llvm22/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export CC=${CC:-clang-22}
export CXX=${CXX:-clang++-22}
export AR=${AR:-/usr/lib/llvm22/bin/llvm-ar}
export RANLIB=${RANLIB:-/usr/lib/llvm22/bin/llvm-ranlib}
export NM=${NM:-/usr/lib/llvm22/bin/llvm-nm}
export STRIP=${STRIP:-/usr/lib/llvm22/bin/llvm-strip}
export READELF=${READELF:-/usr/lib/llvm22/bin/llvm-readelf}
export PKG_CONFIG_LIBDIR=$prefix/lib/pkgconfig:$prefix/share/pkgconfig
export PKG_CONFIG_PATH=
export PKG_CONFIG_SYSROOT_DIR=
export CPPFLAGS=${CPPFLAGS:-"-I$prefix/include"}
export CFLAGS=${CFLAGS:-"-O2 -g0 -fPIC"}
export CXXFLAGS=${CXXFLAGS:-"-O2 -g0 -fPIC"}
export LDFLAGS=${LDFLAGS:-"-fuse-ld=mold -L$prefix/lib -Wl,-rpath-link,$prefix/lib -Wl,--as-needed"}

require_clang() {
  case "$($CC --version | sed -n '1p')" in
    *"clang version 22."*) ;;
    *) printf 'expected clang 22 CC, got: %s\n' "$($CC --version | sed -n '1p')" >&2; exit 1 ;;
  esac
  case "$($CXX --version | sed -n '1p')" in
    *"clang version 22."*) ;;
    *) printf 'expected clang 22 CXX, got: %s\n' "$($CXX --version | sed -n '1p')" >&2; exit 1 ;;
  esac
}

source_row() {
  awk -v package="$1" '$1 == package { print; found = 1 } END { exit found ? 0 : 1 }' "$lock"
}

source_field() {
  local name=$1 field=$2
  source_row "$name" | awk -v field="$field" '{ print $field }'
}

source_version() {
  source_field "$1" 2
}

source_url() {
  source_field "$1" 3
}

source_sha256() {
  source_field "$1" 4
}

archive_path() {
  local name=$1 url
  url=$(source_url "$name")
  printf '%s/%s\n' "$sources" "${url##*/}"
}

fetch_source() {
  local name=$1 url sha archive
  url=$(source_url "$name")
  sha=$(source_sha256 "$name")
  archive=$(archive_path "$name")

  if [ ! -f "$archive" ]; then
    curl -fL "$url" -o "$archive.tmp"
    mv "$archive.tmp" "$archive"
  fi

  printf '%s  %s\n' "$sha" "$archive" | sha256sum -c -
}

unpack_source() {
  local name=$1 archive top
  archive=$(archive_path "$name")
  top=$(tar -tf "$archive" | awk -F/ 'NF { print $1; exit }')
  rm -rf "$build_root/$top"
  tar -xf "$archive" -C "$build_root"
  printf '%s/%s\n' "$build_root" "$top"
}

stamp_path() {
  local name=$1 version
  version=$(source_version "$name")
  printf '%s/.wfx-stamps/%s-%s\n' "$prefix" "$name" "$version"
}

already_built() {
  local stamp
  stamp=$(stamp_path "$1")
  [ "${WFX_FORCE_REBUILD:-0}" != 1 ] && [ -f "$stamp" ]
}

mark_built() {
  local name=$1 stamp
  stamp=$(stamp_path "$name")
  {
    printf 'name=%s\n' "$name"
    printf 'version=%s\n' "$(source_version "$name")"
    printf 'cc=%s\n' "$($CC --version | sed -n '1p')"
    printf 'built_at=%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  } > "$stamp"
}

run_make_install() {
  make -j"$jobs"
  make install
}

meson_build_install() {
  local dir=$1 build=$2
  shift 2
  local sysroot_ld_path="$prefix/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
  meson setup "$dir/$build" "$dir" \
    --prefix="$prefix" \
    --libdir=lib \
    --buildtype=debugoptimized \
    --wrap-mode=nodownload \
    "$@"
  LD_LIBRARY_PATH="$sysroot_ld_path" meson compile -C "$dir/$build" -j "$jobs"
  LD_LIBRARY_PATH="$sysroot_ld_path" meson install --no-rebuild -C "$dir/$build"
}

clean_sysroot() {
  rm -rf \
    "$prefix/share/doc" \
    "$prefix/share/info" \
    "$prefix/share/locale" \
    "$prefix/share/man"
  rm -f \
    "$prefix/bin/xmlwf" \
    "$prefix/bin/pcre2grep" \
    "$prefix/bin/pcre2test"
  find "$prefix/lib" \( -type f -o -type l \) -name '*.la' -delete 2>/dev/null || true
  find "$prefix/lib" \( -type f -o -type l \) -name '*.a' ! -name 'libmimalloc*.a' -delete 2>/dev/null || true
}

build_zlib() {
  local dir
  already_built zlib && return 0
