  build_wayland
  build_wayland_protocols
  build_xkeyboard_config
  build_libxkbcommon
  build_gdk_pixbuf
  build_khronos_headers
  build_libepoxy
  build_at_spi2_core
  build_gtk
  clean_sysroot
  scan_sysroot
}

