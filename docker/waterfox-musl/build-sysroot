scan_sysroot() {
  local reject_regex file failed count
  reject_regex='libX11|libX11-xcb|libxcb|libXcomposite|libXdamage|libXext|libXfixes|libXi|libXinerama|libXrandr|libXrender|libXcursor|libxkbfile|libXt|libSM|libICE|libGLX|libasound|libpipewire|libpulse|libdbus|libnotify|libsecret|libspeechd|libcups|libmimalloc\.so'
  failed=0
  count=0

  while IFS= read -r file; do
    count=$((count + 1))
    if "$READELF" -d "$file" 2>/dev/null | grep -E "$reject_regex"; then
      printf 'rejected dependency in %s\n' "$file" >&2
      failed=1
    fi
  done < <(find "$prefix" -type f \( -name '*.so' -o -name '*.so.*' \) | sort)

  if [ "$count" -eq 0 ]; then
    printf 'no shared libraries found in %s\n' "$prefix" >&2
    exit 1
  fi

  if [ "$failed" -ne 0 ]; then
    exit 1
  fi
}

smoke_compile() {
  local smoke_dir
  smoke_dir=$cache/build/smoke
  mkdir -p "$smoke_dir"

  cat > "$smoke_dir/sysroot-smoke.c" <<'EOF'
#include <stdio.h>
#include <zlib.h>
#include <expat.h>
#include <png.h>
#include <jpeglib.h>
#include <ffi.h>
#include <mimalloc.h>
#define PCRE2_CODE_UNIT_WIDTH 8
#include <pcre2.h>
#include <glib.h>
#include <gtk/gtk.h>
#include <pango/pangocairo.h>
#include <wayland-version.h>
#include <xkbcommon/xkbcommon.h>

int main(void) {
  ffi_cif cif;
  ffi_status status = ffi_prep_cif(&cif, FFI_DEFAULT_ABI, 0, &ffi_type_void, NULL);
  struct jpeg_error_mgr jerr;
  PCRE2_UCHAR version[64];
  PangoFontMap *font_map;
  struct xkb_context *xkb_context;
  struct xkb_keymap *xkb_keymap;
  struct xkb_rule_names names = { "evdev", "pc105", "us", NULL, NULL };
  jpeg_std_error(&jerr);
  pcre2_config(PCRE2_CONFIG_VERSION, version);
  font_map = pango_cairo_font_map_get_default();
  xkb_context = xkb_context_new(XKB_CONTEXT_NO_FLAGS);
  if (xkb_context == NULL) {
    return 2;
  }
  xkb_keymap = xkb_keymap_new_from_names(xkb_context, &names, XKB_KEYMAP_COMPILE_NO_FLAGS);
  if (xkb_keymap == NULL) {
    xkb_context_unref(xkb_context);
    return 3;
  }
  printf("zlib=%s\n", zlibVersion());
  printf("expat=%s\n", XML_ExpatVersion());
  printf("libpng=%u\n", png_access_version_number());
  printf("libjpeg=%d\n", JPEG_LIB_VERSION);
  printf("libffi_status=%d\n", status);
  printf("mimalloc_good_size=%zu\n", mi_good_size(4097));
  printf("pcre2=%s\n", (char *)version);
  printf("glib=%u.%u.%u\n", glib_major_version, glib_minor_version, glib_micro_version);
  printf("gtk=%u.%u.%u\n", gtk_get_major_version(), gtk_get_minor_version(), gtk_get_micro_version());
  printf("pango=%s\n", pango_version_string());
  printf("pangocairo_fontmap=%p\n", (void *)font_map);
  printf("wayland=%s\n", WAYLAND_VERSION);
  printf("xkb_min_keycode=%u\n", xkb_keymap_min_keycode(xkb_keymap));
  xkb_keymap_unref(xkb_keymap);
  xkb_context_unref(xkb_context);
  return status == FFI_OK ? 0 : 1;
}
EOF

  "$CC" \
    -O2 \
    -g0 \
    -fPIC \
    -o "$smoke_dir/sysroot-smoke" \
    "$smoke_dir/sysroot-smoke.c" \
    $(pkgconf --cflags --libs zlib expat libpng libjpeg libffi mimalloc libpcre2-8 glib-2.0 gtk+-3.0 pangocairo wayland-client xkbcommon) \
    -Wl,-rpath,"$prefix/lib"

  LD_LIBRARY_PATH="$prefix/lib" "$smoke_dir/sysroot-smoke"
  "$READELF" -d "$smoke_dir/sysroot-smoke" | grep NEEDED
}

build_initial() {
  require_clang
  build_zlib
  build_expat
  build_libffi
  build_mimalloc
  build_pcre2
  build_libpng
  build_libjpeg_turbo
  build_freetype
