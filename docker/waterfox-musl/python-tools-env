#!/usr/bin/env sh
set -eu

wfx_python_tools_repo_root=${WFX_REPO_ROOT:-${repo_root:-/work}}
wfx_python_tools_cache=${WFX_CACHE:-${cache:-/cache}}
wfx_python_tools_project=$wfx_python_tools_repo_root/docker/waterfox-musl
wfx_python_tools_venv=${WFX_PYTHON_TOOLS_VENV:-$wfx_python_tools_cache/mozbuild/wfx-python-tools}
wfx_python_tools_stamp=$wfx_python_tools_venv/.wfx-tools-pyproject.sha256
wfx_python_tools_expected=$(sha256sum "$wfx_python_tools_project/pyproject.toml" | awk '{ print $1 }')

if [ ! -x "$wfx_python_tools_venv/bin/meson" ] ||
   [ ! -x "$wfx_python_tools_venv/bin/ninja" ] ||
   [ "$(cat "$wfx_python_tools_stamp" 2>/dev/null || true)" != "$wfx_python_tools_expected" ]; then
  uv venv "$wfx_python_tools_venv" >/dev/null
  uv pip install --link-mode=copy \
    --python "$wfx_python_tools_venv/bin/python" \
    --group "$wfx_python_tools_project/pyproject.toml:wfx-tools"
  printf '%s\n' "$wfx_python_tools_expected" > "$wfx_python_tools_stamp"
fi

export PATH=$wfx_python_tools_venv/bin:$PATH
