#!/usr/bin/env bash
set -euo pipefail

cache=${WFX_CACHE:-/cache}
repo_root=${WFX_REPO_ROOT:-/work}
stage=${WFX_STAGE_ROOT:-$cache/dist/stage1-root}
qemu_dir=$cache/qemu
rootfs=$qemu_dir/rootfs
image=$qemu_dir/waterfox-kiosk.ext4
kernel=$qemu_dir/vmlinuz-virt
initramfs=$qemu_dir/initramfs-virt
compositor=${WFX_KIOSK_COMPOSITOR:-/opt/wfx/kiosk-compositor}
image_mb=${WFX_QEMU_IMAGE_MB:-2048}
include_alpine_firefox=${WFX_QEMU_INCLUDE_ALPINE_FIREFOX:-0}
include_weston=${WFX_QEMU_INCLUDE_WESTON:-0}
include_alsa=${WFX_QEMU_INCLUDE_ALSA:-0}
qemu_image_version=11

if [ "$include_alsa" = 1 ] && [ -z "${WFX_STAGE_ROOT+x}" ]; then
  stage=$cache/dist/alsa-debug-root
fi

fail() {
  printf 'wfx qemu image failed: %s\n' "$*" >&2
  exit 1
}

require_path() {
  [ -e "$1" ] || fail "missing $1"
}

install_rootfs_packages() {
  apk update --cache-dir /var/cache/apk >/dev/null
  apk add --cache-dir /var/cache/apk --no-progress e2fsprogs mkinitfs >/dev/null
  rm -rf "$rootfs"
  mkdir -p "$rootfs"
  apk --root "$rootfs" \
    --arch aarch64 \
    --initdb \
    --keys-dir /etc/apk/keys \
    --repositories-file /etc/apk/repositories \
    --cache-dir /var/cache/apk \
    add --no-progress --no-scripts \
      alpine-base \
      ca-certificates \
      eudev \
      eudev-libs \
      font-dejavu \
      fontconfig \
      gtk+3.0 \
      hwdata \
      libdisplay-info \
      libdrm \
      libevdev \
      libgcc \
      libinput \
      libintl \
      libpciaccess \
      libseat \
      libstdc++ \
      libxkbcommon \
      linux-firmware-none \
      linux-virt \
      mesa-dri-gallium \
      mesa-egl \
      mesa-gbm \
      mesa-gles \
      mtdev \
      openrc \
      pixman \
      pciutils-libs \
      seatd \
      shared-mime-info \
      wayland >/dev/null
  if [ "$include_alsa" = 1 ]; then
    apk --root "$rootfs" \
      --arch aarch64 \
      --keys-dir /etc/apk/keys \
      --repositories-file /etc/apk/repositories \
      --cache-dir /var/cache/apk \
      add --no-progress --no-scripts alsa-lib alsa-utils >/dev/null
    mkdir -p "$rootfs/etc"
    cat > "$rootfs/etc/asound.conf" <<'EOF'
defaults.pcm.card 0
defaults.ctl.card 0

pcm.!default {
  type plug
  slave.pcm "hw:0,0"
}

ctl.!default {
  type hw
  card 0
}
EOF
  fi
  if [ "$include_alpine_firefox" = 1 ]; then
    apk --root "$rootfs" \
      --arch aarch64 \
      --keys-dir /etc/apk/keys \
      --repositories-file /etc/apk/repositories \
      --cache-dir /var/cache/apk \
      add --no-progress --no-scripts firefox >/dev/null
  fi
  if [ "$include_weston" = 1 ]; then
    apk --root "$rootfs" \
      --arch aarch64 \
      --keys-dir /etc/apk/keys \
      --repositories-file /etc/apk/repositories \
      --cache-dir /var/cache/apk \
      add --no-progress --no-scripts weston weston-backend-drm >/dev/null
  fi
  chroot "$rootfs" /bin/busybox --install -s
  mkdir -p "$rootfs/usr/lib/gdk-pixbuf-2.0/2.10.0"
  chroot "$rootfs" /usr/bin/gdk-pixbuf-query-loaders --update-cache >/dev/null 2>&1 || true
  chroot "$rootfs" /usr/bin/update-mime-database /usr/share/mime >/dev/null 2>&1 || true
}

install_payloads() {
  require_path "$stage/opt/waterfox"
  require_path "$stage/opt/wfx/sysroot"
  require_path "$stage/usr/bin/waterfox"
  require_path "$compositor/bin/cage"

  mkdir -p "$rootfs/opt" "$rootfs/usr/bin"
  rm -rf "$rootfs/opt/waterfox" "$rootfs/opt/wfx" "$rootfs/usr/bin/waterfox" "$rootfs/usr/bin/wfx-gtk-popup-repro"
  cp -a "$stage/opt/waterfox" "$rootfs/opt/waterfox"
  mkdir -p "$rootfs/opt/wfx"
  cp -a "$stage/opt/wfx/sysroot" "$rootfs/opt/wfx/sysroot"
  cp -a "$compositor" "$rootfs/opt/wfx/kiosk-compositor"
  cp -a "$stage/usr/bin/waterfox" "$rootfs/usr/bin/waterfox"
  clang-22 \
    $(pkg-config --cflags gtk+-3.0) \
    "$repo_root/docker/waterfox-musl/gtk-popup-repro.c" \
    -o "$rootfs/usr/bin/wfx-gtk-popup-repro" \
    $(pkg-config --libs gtk+-3.0)
  mkdir -p "$rootfs/usr/share/wfx"
  cat > "$rootfs/usr/share/wfx/audio-test.html" <<'EOF'
<!doctype html>
<meta charset="utf-8">
<title>Waterfox ALSA audio test</title>
<body>
<script>
"use strict";

async function start() {
  const context = new AudioContext({ sampleRate: 48000 });
  const gain = new GainNode(context, { gain: 0.20 });
  const oscillator = new OscillatorNode(context, { frequency: 880, type: "sine" });
  oscillator.connect(gain).connect(context.destination);
  oscillator.start();
  await context.resume();
  document.title = `Waterfox ALSA audio test: ${context.state}`;
  setInterval(() => context.resume(), 1000);
}

start().catch(error => {
  document.title = `Waterfox ALSA audio test failed: ${error}`;
});
</script>
EOF
}

install_kiosk_init() {
  mkdir -p "$rootfs/usr/local/bin" "$rootfs/dev/pts" "$rootfs/run" "$rootfs/tmp" "$rootfs/var/log"
  chmod 1777 "$rootfs/tmp"
  cat > "$rootfs/usr/local/bin/wfx-kiosk-init" <<'EOF'
#!/bin/sh
set -eu

mount -t proc proc /proc || true
mount -t sysfs sysfs /sys || true
mount -t devtmpfs devtmpfs /dev || true
mount -o remount,rw / || true
mkdir -p /dev/pts /run /tmp /var/log
mount -t devpts devpts /dev/pts || true
mountpoint -q /run || mount -t tmpfs tmpfs /run
mountpoint -q /tmp || mount -t tmpfs tmpfs /tmp
chmod 1777 /tmp
if ! touch /run/.wfx-write-test 2>/dev/null; then
  echo "wfx-kiosk-init: /run is not writable" >/dev/console
  exit 1
fi
rm -f /run/.wfx-write-test

export PATH=/opt/wfx/kiosk-compositor/bin:/usr/sbin:/usr/bin:/sbin:/bin
mkdir -p /run/udev
for module in evdev virtio_input virtio_net virtio-gpu bochs simpledrm qxl hid hid_generic usbhid xhci_hcd xhci_pci; do
  if ! modprobe "$module" >/dev/console 2>&1; then
    echo "wfx-kiosk-init: failed to load module $module" >/dev/console
  fi
done
udevd --daemon 2>/dev/console || true
udevadm trigger --action=add 2>/dev/console || true
udevadm settle --timeout=5 2>/dev/console || true
ip link set lo up >/dev/console 2>&1 || true
for iface in /sys/class/net/*; do
  iface=${iface##*/}
  [ "$iface" != lo ] || continue
  ip link set "$iface" up >/dev/console 2>&1 || true
  udhcpc -q -n -i "$iface" >/dev/console 2>&1 || echo "wfx-kiosk-init: DHCP failed on $iface" >/dev/console
  break
done
export LD_LIBRARY_PATH=/opt/wfx/kiosk-compositor/lib:/opt/waterfox:/opt/wfx/sysroot/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}
export XDG_RUNTIME_DIR=/run/user/0
export HOME=/run/wfx-home
export XDG_CACHE_HOME=/run/wfx-cache
export WAYLAND_DISPLAY=wayland-0
export MOZ_ENABLE_WAYLAND=1
export GDK_BACKEND=wayland
export NO_AT_BRIDGE=1
export LIBGL_ALWAYS_SOFTWARE=1
export GALLIUM_DRIVER=llvmpipe
export MESA_LOADER_DRIVER_OVERRIDE=kms_swrast
export MESA_EXTENSION_OVERRIDE="-EGL_EXT_buffer_age -EGL_KHR_partial_update"
export MOZ_DISABLE_AUTO_SAFE_MODE=1
export MOZ_CRASHREPORTER_DISABLE=1
export MOZ_DISABLE_CONTENT_SANDBOX=1
export MOZ_DISABLE_GMP_SANDBOX=1
export MOZ_DISABLE_GPU_SANDBOX=1
export MOZ_DISABLE_RDD_SANDBOX=1
export MOZ_DISABLE_SOCKET_PROCESS_SANDBOX=1
export MALLOC_OPTIONS=R
export MOZ_WAYLAND_FULL_DAMAGE=1
export WLR_BACKENDS=drm,libinput
export WLR_DRM_NO_ATOMIC=1
export WLR_RENDERER=pixman
export WLR_RENDERER_ALLOW_SOFTWARE=1
export WLR_SCENE_DEBUG_DAMAGE=rerender
export WLR_SCENE_DISABLE_DIRECT_SCANOUT=1
export WLR_SCENE_DISABLE_VISIBILITY=1
export SEATD_SOCK=/run/seatd.sock
audio_enabled=0
for arg in $(cat /proc/cmdline); do
  case "$arg" in
    wfx.audio=1)
      audio_enabled=1
      ;;
  esac
done
profile=/run/wfx-profile
browser=/usr/bin/waterfox
browser_ld_library_path=$LD_LIBRARY_PATH
browser_args="-no-remote -profile $profile about:blank"
compositor=cage
software_webrender=0
full_damage=1
pref_profile=default
audio_test=0
moz_log=
for arg in $(cat /proc/cmdline); do
  case "$arg" in
    wfx.browser=gtk-popup-repro)
      browser=/usr/bin/wfx-gtk-popup-repro
      browser_ld_library_path=/opt/wfx/kiosk-compositor/lib
      browser_args=
      ;;
    wfx.browser=firefox)
      browser=/usr/bin/firefox
      browser_ld_library_path=/opt/wfx/kiosk-compositor/lib
      browser_args="-no-remote -profile $profile about:blank"
      ;;
    wfx.browser=waterfox)
      browser=/usr/bin/waterfox
      browser_ld_library_path=$LD_LIBRARY_PATH
      browser_args="-no-remote -profile $profile about:blank"
      ;;
    wfx.compositor=weston)
      compositor=weston
      ;;
    wfx.compositor=cage)
      compositor=cage
      ;;
    wfx.wlr_renderer=*)
      value=${arg#*=}
      if [ "$value" = unset ]; then
        unset WLR_RENDERER
      else
        export WLR_RENDERER=$value
      fi
      ;;
    wfx.drm_no_atomic=*)
      value=${arg#*=}
      if [ "$value" = unset ]; then
        unset WLR_DRM_NO_ATOMIC
      else
        export WLR_DRM_NO_ATOMIC=$value
      fi
      ;;
    wfx.scene_debug_damage=*)
      value=${arg#*=}
      if [ "$value" = unset ]; then
        unset WLR_SCENE_DEBUG_DAMAGE
      else
        export WLR_SCENE_DEBUG_DAMAGE=$value
      fi
      ;;
    wfx.scene_disable_direct_scanout=*)
      value=${arg#*=}
      if [ "$value" = unset ]; then
        unset WLR_SCENE_DISABLE_DIRECT_SCANOUT
      else
        export WLR_SCENE_DISABLE_DIRECT_SCANOUT=$value
      fi
      ;;
    wfx.scene_disable_visibility=*)
      value=${arg#*=}
      if [ "$value" = unset ]; then
        unset WLR_SCENE_DISABLE_VISIBILITY
      else
        export WLR_SCENE_DISABLE_VISIBILITY=$value
      fi
      ;;
    wfx.software_webrender=*)
      software_webrender=${arg#*=}
      ;;
    wfx.full_damage=*)
      full_damage=${arg#*=}
      ;;
    wfx.gallium_driver=*)
      export GALLIUM_DRIVER=${arg#*=}
      ;;
    wfx.mesa_loader=*)
      export MESA_LOADER_DRIVER_OVERRIDE=${arg#*=}
      ;;
    wfx.pref_profile=*)
      pref_profile=${arg#*=}
      ;;
    wfx.audio=1)
      audio_enabled=1
      ;;
    wfx.audio_test=1)
      audio_test=1
      ;;
    wfx.moz_log=*)
      moz_log=${arg#*=}
      ;;
  esac
done

echo "wfx-kiosk-init: profile=$profile" >/dev/console
echo "wfx-kiosk-init: renderer=${WLR_RENDERER-unset}" >/dev/console
echo "wfx-kiosk-init: drm_no_atomic=${WLR_DRM_NO_ATOMIC-unset}" >/dev/console
echo "wfx-kiosk-init: scene_debug_damage=${WLR_SCENE_DEBUG_DAMAGE-unset}" >/dev/console
echo "wfx-kiosk-init: scene_disable_direct_scanout=${WLR_SCENE_DISABLE_DIRECT_SCANOUT-unset}" >/dev/console
echo "wfx-kiosk-init: scene_disable_visibility=${WLR_SCENE_DISABLE_VISIBILITY-unset}" >/dev/console
echo "wfx-kiosk-init: software_webrender=$software_webrender" >/dev/console
echo "wfx-kiosk-init: full_damage=$full_damage" >/dev/console
echo "wfx-kiosk-init: pref_profile=$pref_profile" >/dev/console
echo "wfx-kiosk-init: audio_enabled=$audio_enabled" >/dev/console
echo "wfx-kiosk-init: audio_test=$audio_test" >/dev/console
echo "wfx-kiosk-init: moz_log=${moz_log:-unset}" >/dev/console
echo "wfx-kiosk-init: browser=$browser" >/dev/console
echo "wfx-kiosk-init: compositor=$compositor" >/dev/console
mkdir -p "$XDG_RUNTIME_DIR" "$HOME" "$XDG_CACHE_HOME"
chmod 0700 "$XDG_RUNTIME_DIR"
rm -rf "$profile"
mkdir -p "$profile"
cat > "$profile/user.js" <<'PROFILE_EOF'
user_pref("app.normandy.enabled", false);
user_pref("browser.backup.enabled", false);
user_pref("browser.dom.window.dump.enabled", false);
user_pref("browser.opaqueResponseBlocking.javascriptValidator", false);
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.startup.homepage", "about:blank");
user_pref("browser.startup.page", 0);
user_pref("browser.urlbar.speculativeConnect.enabled", false);
user_pref("datareporting.healthreport.uploadEnabled", false);
user_pref("devtools.console.stdout.chrome", false);
user_pref("devtools.console.stdout.content", false);
user_pref("gfx.webrender.enable-gpu-markers", false);
user_pref("gfx.webrender.allow-partial-present-buffer-age", false);
user_pref("gfx.webrender.force-partial-present", false);
user_pref("gfx.webrender.max-partial-present-rects", 0);
user_pref("gfx.webrender.reject-software-driver", false);
user_pref("widget.dmabuf.enabled", false);
user_pref("network.captive-portal-service.enabled", false);
user_pref("network.connectivity-service.enabled", false);
user_pref("network.dns.disableIPv6", true);
user_pref("network.http.http3.enable", false);
user_pref("network.http.speculative-parallel-limit", 0);
user_pref("network.predictor.enabled", false);
user_pref("network.prefetch-next", false);
user_pref("network.trr.bootstrapAddress", "");
user_pref("network.trr.mode", 5);
user_pref("network.trr.uri", "");
user_pref("toolkit.telemetry.enabled", false);
user_pref("waterfox.blocker.enabled", false);
user_pref("waterfox.blocker.remoteResourcesEnabled", false);
user_pref("waterfox.blocker.ui.enabled", false);
PROFILE_EOF
if [ "$audio_test" = 1 ]; then
  browser_args="-no-remote -profile $profile file:///usr/share/wfx/audio-test.html"
  echo 'user_pref("media.autoplay.default", 0);' >> "$profile/user.js"
  echo 'user_pref("media.autoplay.blocking_policy", 0);' >> "$profile/user.js"
  echo 'user_pref("media.autoplay.block-event.enabled", false);' >> "$profile/user.js"
fi
old_ifs=$IFS
IFS=,
for profile_name in $pref_profile; do
  case "$profile_name" in
    default|"")
      ;;
    move-to-rect-off)
      echo 'user_pref("widget.wayland.use-move-to-rect", false);' >> "$profile/user.js"
      ;;
    popup-simple)
      echo 'user_pref("widget.wayland.use-move-to-rect", false);' >> "$profile/user.js"
      echo 'user_pref("widget.gtk.grab-pointer", 0);' >> "$profile/user.js"
      echo 'user_pref("apz.popups.enabled", false);' >> "$profile/user.js"
      echo 'user_pref("apz.popups_without_remote.enabled", false);' >> "$profile/user.js"
      ;;
    single-process)
      echo 'user_pref("browser.tabs.remote.autostart", false);' >> "$profile/user.js"
      echo 'user_pref("fission.autostart", false);' >> "$profile/user.js"
      echo 'user_pref("dom.ipc.processCount", 1);' >> "$profile/user.js"
      echo 'user_pref("dom.ipc.processCount.webIsolated", 1);' >> "$profile/user.js"
      echo 'user_pref("dom.ipc.processPrelaunch.enabled", false);' >> "$profile/user.js"
      ;;
    simple-gfx)
      echo 'user_pref("gfx.webrender.enable-item-cache", false);' >> "$profile/user.js"
      echo 'user_pref("gfx.webrender.batched-texture-uploads", false);' >> "$profile/user.js"
      echo 'user_pref("gfx.webrender.scissored-cache-clears.enabled", false);' >> "$profile/user.js"
      echo 'user_pref("gfx.webrender.prefer-robustness", false);' >> "$profile/user.js"
      echo 'user_pref("gfx.webrender.pbo-uploads", false);' >> "$profile/user.js"
      ;;
    no-apz)
      echo 'user_pref("layers.async-pan-zoom.enabled", false);' >> "$profile/user.js"
      echo 'user_pref("apz.popups.enabled", false);' >> "$profile/user.js"
      echo 'user_pref("apz.popups_without_remote.enabled", false);' >> "$profile/user.js"
      ;;
    *)
      echo "wfx-kiosk-init: unknown pref_profile=$profile_name" >/dev/console
      ;;
  esac
done
IFS=$old_ifs
if [ "$software_webrender" = 1 ]; then
  export MOZ_WEBRENDER_SOFTWARE=1
  echo 'user_pref("gfx.webrender.software", true);' >> "$profile/user.js"
else
  unset MOZ_WEBRENDER_SOFTWARE
  echo 'user_pref("gfx.webrender.software", false);' >> "$profile/user.js"
fi
if [ "$full_damage" = 1 ]; then
  export MOZ_WAYLAND_FULL_DAMAGE=1
else
  unset MOZ_WAYLAND_FULL_DAMAGE
fi
if [ -n "$moz_log" ]; then
  export MOZ_LOG=$moz_log
fi
if [ "$audio_enabled" = 1 ]; then
  export CUBEB_BACKEND=alsa
  for module in snd snd_pcm snd_timer virtio_snd; do
    if ! modprobe "$module" >/dev/console 2>&1; then
      echo "wfx-kiosk-init: failed to load audio module $module" >/dev/console
    fi
  done
  if command -v aplay >/dev/null 2>&1; then
    aplay -l >/dev/console 2>&1 || echo "wfx-kiosk-init: aplay -l failed" >/dev/console
  fi
  if command -v amixer >/dev/null 2>&1; then
    for control in Master PCM Speaker Headphone; do
      amixer -q sset "$control" 100% unmute >/dev/console 2>&1 || true
    done
  fi
fi

seatd -u root -g root -l error >/dev/console 2>&1 &
sleep 1

case "$compositor" in
  weston)
    if ! command -v weston >/dev/null 2>&1; then
      echo "wfx-kiosk-init: weston is not installed; rebuild with WFX_QEMU_INCLUDE_WESTON=1" >/dev/console
      exit 1
    fi
    weston --backend=drm --renderer=pixman --shell=kiosk-shell.so --socket="$WAYLAND_DISPLAY" --idle-time=0 --no-config --continue-without-input --log=/dev/console -- env LD_LIBRARY_PATH="$browser_ld_library_path" "$browser" $browser_args >/dev/console 2>&1 &
    compositor_pid=$!
    ;;
  *)
    cage -- env LD_LIBRARY_PATH="$browser_ld_library_path" "$browser" $browser_args >/dev/console 2>&1 &
    compositor_pid=$!
    ;;
esac
status=0
wait "$compositor_pid" || status=$?
echo "wfx-kiosk-init: $compositor exited with status $status" >/dev/console
poweroff -f >/dev/console 2>&1 || true
while :; do
  sleep 3600
done
EOF
  chmod 0755 "$rootfs/usr/local/bin/wfx-kiosk-init"
}

create_initramfs() {
  local kver
  kver=$(basename "$(find "$rootfs/lib/modules" -mindepth 1 -maxdepth 1 -type d | sort | tail -n 1)")
  if [ -z "$kver" ]; then
    fail "could not determine linux-virt kernel version"
  fi
  mkinitfs \
    -b "$rootfs" \
    -F "base virtio kms ext2 ext4" \
    -o "$rootfs/boot/initramfs-virt" \
    "$kver"
}

create_image() {
  local rootfs_kb image_kb tmp_image
  rm -f "$rootfs/bin/bbsuid"
  rootfs_kb=$(du -sk "$rootfs" 2>/dev/null | awk '{ print $1 }' || :)
  if [ -z "$rootfs_kb" ]; then
    fail "could not size rootfs"
  fi
  image_kb=$((image_mb * 1024))
  if [ "$rootfs_kb" -ge "$image_kb" ]; then
    fail "rootfs is ${rootfs_kb}KiB, larger than WFX_QEMU_IMAGE_MB=$image_mb"
  fi
  rm -f "$image"
  find "$rootfs/lib/modules" -type f \( \
    -name 'xt_RATEEST.ko.gz' -o \
    -name 'xt_DSCP.ko.gz' -o \
    -name 'xt_TCPMSS.ko.gz' -o \
    -name 'xt_HL.ko.gz' \) -delete 2>/dev/null || true
  tmp_image=$image.tmp
  rm -f "$tmp_image"
  truncate -s "${image_mb}M" "$tmp_image"
  mkfs.ext4 -q -F -E no_copy_xattrs -L WFXROOT -d "$rootfs" "$tmp_image"
  e2fsck -fy "$tmp_image" >/dev/null
  mv -f "$tmp_image" "$image"
  cp -a "$rootfs/boot/vmlinuz-virt" "$kernel"
  if [ -f "$rootfs/boot/initramfs-virt" ]; then
    cp -a "$rootfs/boot/initramfs-virt" "$initramfs"
  else
    rm -f "$initramfs"
  fi
}

write_manifest() {
  {
    printf 'qemu_image_version=%s\n' "$qemu_image_version"
    printf 'image=%s\n' "$image"
    printf 'kernel=%s\n' "$kernel"
    printf 'initramfs=%s\n' "$initramfs"
    printf 'rootfs=%s\n' "$rootfs"
    printf 'image_mb=%s\n' "$image_mb"
    printf 'init_profile=/run/wfx-profile\n'
    printf 'include_alpine_firefox=%s\n' "$include_alpine_firefox"
    printf 'include_weston=%s\n' "$include_weston"
    printf 'include_alsa=%s\n' "$include_alsa"
    printf 'created_utc=%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf 'waterfox_stage=%s\n' "$stage"
    printf 'compositor=%s\n' "$compositor"
  } > "$qemu_dir/waterfox-kiosk.manifest.txt"
}

build_image() {
  mkdir -p "$qemu_dir"
  install_rootfs_packages
  install_payloads
  install_kiosk_init
  create_initramfs
  create_image
  write_manifest
  printf 'Created QEMU image: %s\n' "$image"
}

case "${1:-build}" in
  build)
    build_image
    ;;
  *)
    printf 'usage: %s [build]\n' "$0" >&2
    exit 2
    ;;
esac
