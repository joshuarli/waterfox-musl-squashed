  mkdir -p \
    "$cache_dir/apk" \
    "$cache_dir/sources" \
    "$cache_dir/build" \
    "$cache_dir/build-deps" \
    "$cache_dir/test-compositor" \
    "$cache_dir/kiosk-compositor" \
    "$cache_dir/sysroot" \
    "$cache_dir/mozbuild" \
    "$cache_dir/sccache" \
    "$cache_dir/cargo" \
    "$cache_dir/obj-aarch64-unknown-linux-musl" \
    "$cache_dir/obj-aarch64-alpine-linux-musl" \
    "$cache_dir/obj-aarch64-alpine-linux-musl/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-alsa-debug/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-folded/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-minwayland/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-minwayland-release/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-release/dist/system_wrappers" \
