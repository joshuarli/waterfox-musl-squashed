#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd "$script_dir/../.." && pwd)

image=${WFX_IMAGE:-waterfox-musl:edge-clang22}
platform=${WFX_DOCKER_PLATFORM:-linux/arm64}
cache_dir=${WFX_CACHE_DIR:-$repo_root/.wfx-cache}
default_mozconfig=/work/docker/waterfox-musl/mozconfig.stage1
alsa_debug_mozconfig=/work/docker/waterfox-musl/mozconfig.alsa-debug
release_mozconfig=/work/docker/waterfox-musl/mozconfig.release
folded_release_mozconfig=/work/docker/waterfox-musl/mozconfig.folded-release
minwayland_mozconfig=/work/docker/waterfox-musl/mozconfig.minwayland

usage() {
  cat <<'EOF'
usage: docker/waterfox-musl/wfx-musl <command>

commands:
  image             Build the Alpine edge clang22 toolchain image.
  versions          Report current Alpine edge package versions.
  toolchain-report  Report selected compiler, linker, Rust, and cache tools.
  shell             Open an interactive shell in the toolchain container.
  sysroot           Reserved for the custom Wayland/GTK sysroot tranche.
  sysroot-smoke     Compile and run a small program against the custom sysroot.
  configure-check   Verify the generated stage 1 Gecko configuration.
  configure         Reserved for the Gecko patch/configure tranche.
  configure-minwayland
                    Configure the experimental minimal Wayland widget backend.
  build-minwayland Build the experimental minimal Wayland widget backend.
  build             Reserved for the Waterfox build tranche.
  package           Reserved for the package tranche.
  configure-alsa    Configure the debug ALSA build.
  build-alsa        Build the debug ALSA build.
  package-alsa      Package the debug ALSA build.
  check             Reserved for static dependency checks.
  waterfox-deps     Verify final staged Waterfox ELF dependencies.
  configure-release Configure the optimized release build.
  build-release     Build the optimized release build.
  package-release   Package the optimized release build.
  configure-folded-release
                    Configure the experimental folded-library release build.
  build-folded-release
                    Build the experimental folded-library release build.
  package-folded-release
                    Package the experimental folded-library release build.
  smoke-headless    Reserved for Docker headless Wayland/cage smoke.
  kiosk-compositor  Build the custom DRM/libinput cage compositor.
  qemu-image        Assemble the QEMU Alpine aarch64 kiosk rootfs image.
  qemu-run          Boot the QEMU visible kiosk proof.
  qemu-audio        Boot QEMU, capture Waterfox audio to WAV, and verify it.
EOF
}

ensure_cache_dirs() {
  mkdir -p \
    "$cache_dir/apk" \
    "$cache_dir/sources" \
    "$cache_dir/build" \
    "$cache_dir/build-deps" \
    "$cache_dir/test-compositor" \
    "$cache_dir/kiosk-compositor" \
    "$cache_dir/sysroot" \
    "$cache_dir/mozbuild" \
    "$cache_dir/sccache" \
    "$cache_dir/cargo" \
    "$cache_dir/obj-aarch64-unknown-linux-musl" \
    "$cache_dir/obj-aarch64-alpine-linux-musl" \
    "$cache_dir/obj-aarch64-alpine-linux-musl/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-alsa-debug/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-minwayland/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-release/dist/system_wrappers" \
    "$cache_dir/obj-aarch64-alpine-linux-musl-folded-release/dist/system_wrappers" \
    "$cache_dir/dist" \
    "$cache_dir/test-rootfs" \
    "$cache_dir/qemu"
}

build_image() {
  DOCKER_BUILDKIT=1 docker build \
    --platform "$platform" \
    --tag "$image" \
    --file "$script_dir/Dockerfile" \
    "$script_dir"
}

run_in_image() {
  local container_mozconfig
  container_mozconfig=${WFX_MOZCONFIG:-$default_mozconfig}
  ensure_cache_dirs
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    build_image
  fi
  docker run \
    --rm \
    --platform "$platform" \
    --volume "$repo_root:/work" \
    --volume "$cache_dir:/cache" \
    --volume "$cache_dir/build-deps:/opt/wfx/build-deps" \
    --volume "$cache_dir/test-compositor:/opt/wfx/test-compositor" \
    --volume "$cache_dir/kiosk-compositor:/opt/wfx/kiosk-compositor" \
    --volume "$cache_dir/sysroot:/opt/wfx/sysroot" \
    --volume "$cache_dir/apk:/var/cache/apk" \
    --workdir /work \
    --env MOZCONFIG="$container_mozconfig" \
    --env WFX_SKIP_MACH_OPTIONAL=1 \
    --env WFX_JOBS="${WFX_JOBS:-4}" \
    --env WFX_CARGO_JOBS="${WFX_CARGO_JOBS:-4}" \
    --env WFX_FORCE_REBUILD="${WFX_FORCE_REBUILD:-0}" \
    --env WFX_QEMU_IMAGE_MB="${WFX_QEMU_IMAGE_MB:-2048}" \
    --env WFX_QEMU_INCLUDE_ALPINE_FIREFOX="${WFX_QEMU_INCLUDE_ALPINE_FIREFOX:-0}" \
    --env WFX_QEMU_INCLUDE_WESTON="${WFX_QEMU_INCLUDE_WESTON:-0}" \
    --env WFX_QEMU_INCLUDE_ALSA="${WFX_QEMU_INCLUDE_ALSA:-0}" \
    "$image" \
    "$@"
}

run_shell() {
  local container_mozconfig
  container_mozconfig=${WFX_MOZCONFIG:-$default_mozconfig}
  ensure_cache_dirs
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    build_image
  fi
  docker run \
    --rm \
    --interactive \
    --tty \
    --platform "$platform" \
    --volume "$repo_root:/work" \
    --volume "$cache_dir:/cache" \
    --volume "$cache_dir/build-deps:/opt/wfx/build-deps" \
    --volume "$cache_dir/test-compositor:/opt/wfx/test-compositor" \
    --volume "$cache_dir/kiosk-compositor:/opt/wfx/kiosk-compositor" \
    --volume "$cache_dir/sysroot:/opt/wfx/sysroot" \
    --volume "$cache_dir/apk:/var/cache/apk" \
    --workdir /work \
    --env MOZCONFIG="$container_mozconfig" \
    --env WFX_SKIP_MACH_OPTIONAL=1 \
    --env WFX_JOBS="${WFX_JOBS:-4}" \
    --env WFX_CARGO_JOBS="${WFX_CARGO_JOBS:-4}" \
    --env WFX_FORCE_REBUILD="${WFX_FORCE_REBUILD:-0}" \
    --env WFX_QEMU_IMAGE_MB="${WFX_QEMU_IMAGE_MB:-2048}" \
    --env WFX_QEMU_INCLUDE_ALPINE_FIREFOX="${WFX_QEMU_INCLUDE_ALPINE_FIREFOX:-0}" \
    --env WFX_QEMU_INCLUDE_WESTON="${WFX_QEMU_INCLUDE_WESTON:-0}" \
    --env WFX_QEMU_INCLUDE_ALSA="${WFX_QEMU_INCLUDE_ALSA:-0}" \
    "$image" \
    bash
}

uses_default_qemu_artifacts() {
  [ -z "${WFX_QEMU_IMAGE+x}" ] &&
    [ -z "${WFX_QEMU_KERNEL+x}" ] &&
    [ -z "${WFX_QEMU_INITRAMFS+x}" ]
}

refresh_qemu_image() {
  run_in_image sh -euc '/work/docker/waterfox-musl/build-kiosk-compositor build && /work/docker/waterfox-musl/qemu-image build'
}

run_release_in_image() {
  WFX_MOZCONFIG=$release_mozconfig run_in_image "$@"
}

run_alsa_debug_in_image() {
  WFX_MOZCONFIG=$alsa_debug_mozconfig run_in_image "$@"
}

run_folded_release_in_image() {
  WFX_MOZCONFIG=$folded_release_mozconfig run_in_image "$@"
}

run_minwayland_in_image() {
  WFX_MOZCONFIG=$minwayland_mozconfig run_in_image "$@"
}

edge_versions() {
  run_in_image sh -euc '
apk update --cache-dir /var/cache/apk >/dev/null
packages="
clang21
clang21-libclang
clang22
lld22
llvm22
rust
cargo
cbindgen
sccache
ninja-build
mold
samurai
meson
cmake
pkgconf
python3
nodejs-current
alsa-lib
alsa-lib-dev
alsa-utils
gtk+3.0
cairo
glib
pango
gdk-pixbuf
harfbuzz
fontconfig
freetype
libpng
libjpeg-turbo
pixman
wayland
wayland-protocols
libxkbcommon
libepoxy
mesa
expat
libffi
pcre2
zlib
fribidi
shared-mime-info
at-spi2-core
libdrm
libinput
libseat
seatd
libevdev
mtdev
eudev-libs
hwdata
libdisplay-info
libliftoff
mimalloc2
cage
wlroots0.20
qemu-system-aarch64
qemu-img
"
printf 'alpine='
cat /etc/alpine-release
printf 'arch='
apk --print-arch
for package in $packages; do
  apk search -x "$package" | tail -n 1
done
'
}

reserved() {
  printf '%s\n' "not implemented in tranche 1; see PLAN.md for the staged design" >&2
  exit 2
}

command=${1:-}
case "$command" in
  image)
    ensure_cache_dirs
    build_image
    ;;
  versions)
    edge_versions
    ;;
  toolchain-report)
    run_in_image wfx-toolchain-report
    ;;
  shell)
    run_shell
    ;;
  sysroot)
    run_in_image /work/docker/waterfox-musl/build-sysroot build-initial
    ;;
  sysroot-smoke)
    run_in_image /work/docker/waterfox-musl/build-sysroot smoke
    ;;
  check)
    run_in_image sh -euc '/work/docker/waterfox-musl/build-sysroot scan && if [ -d /cache/dist/stage1-root/opt/waterfox ]; then /work/docker/waterfox-musl/check-waterfox-deps; fi'
    ;;
  waterfox-deps)
    run_in_image /work/docker/waterfox-musl/check-waterfox-deps
    ;;
  configure-check)
    run_in_image /work/docker/waterfox-musl/check-config
    ;;
  configure)
    run_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && /work/docker/waterfox-musl/check-config'
    ;;
  configure-minwayland)
    run_minwayland_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure'
    ;;
  build-minwayland)
    run_minwayland_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && ./mach build'
    ;;
  build)
    run_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && /work/docker/waterfox-musl/check-config && ./mach build'
    ;;
  package)
    run_in_image sh -euc './mach package && /work/docker/waterfox-musl/package-stage1'
    ;;
  configure-alsa)
    run_alsa_debug_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-alsa-debug WFX_CONFIG_MODE=alsa-debug /work/docker/waterfox-musl/check-config'
    ;;
  build-alsa)
    run_alsa_debug_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-alsa-debug WFX_CONFIG_MODE=alsa-debug /work/docker/waterfox-musl/check-config && ./mach build'
    ;;
  package-alsa)
    run_alsa_debug_in_image sh -euc './mach package && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-alsa-debug WFX_STAGE_ROOT=/cache/dist/alsa-debug-root WFX_STAGE_ARTIFACT_SUFFIX=alsa-debug WFX_PACKAGE_ALSA=1 WFX_WATERFOX_ALLOW_ALSA=1 /work/docker/waterfox-musl/package-stage1'
    ;;
  configure-release)
    run_release_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-release WFX_CONFIG_MODE=release /work/docker/waterfox-musl/check-config'
    ;;
  build-release)
    run_release_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-release WFX_CONFIG_MODE=release /work/docker/waterfox-musl/check-config && ./mach build'
    ;;
  package-release)
    run_release_in_image sh -euc './mach package && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-release WFX_STAGE_ROOT=/cache/dist/release-root WFX_STAGE_ARTIFACT_SUFFIX=release /work/docker/waterfox-musl/package-stage1'
    ;;
  configure-folded-release)
    run_folded_release_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-folded-release WFX_CONFIG_MODE=release WFX_EXPECT_FOLD_LIBS=1 /work/docker/waterfox-musl/check-config'
    ;;
  build-folded-release)
    run_folded_release_in_image sh -euc 'WFX_SYSROOT=/opt/wfx/build-deps/mimalloc /work/docker/waterfox-musl/build-sysroot build-mimalloc && ./mach configure && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-folded-release WFX_CONFIG_MODE=release WFX_EXPECT_FOLD_LIBS=1 /work/docker/waterfox-musl/check-config && ./mach build'
    ;;
  package-folded-release)
    run_folded_release_in_image sh -euc './mach package && MOZ_OBJDIR=/cache/obj-aarch64-alpine-linux-musl-folded-release WFX_STAGE_ROOT=/cache/dist/folded-release-root WFX_STAGE_ARTIFACT_SUFFIX=folded-release WFX_WATERFOX_ALLOWED_NEEDED=/work/docker/waterfox-musl/waterfox-folded-allowed-needed.txt /work/docker/waterfox-musl/package-stage1'
    ;;
  test-compositor)
    run_in_image /work/docker/waterfox-musl/build-test-compositor build
    ;;
  smoke-headless)
    run_in_image sh -euc '/work/docker/waterfox-musl/build-test-compositor build && /work/docker/waterfox-musl/smoke-headless'
    ;;
  kiosk-compositor)
    run_in_image /work/docker/waterfox-musl/build-kiosk-compositor build
    ;;
  qemu-image)
    refresh_qemu_image
    ;;
  qemu-run)
    "$script_dir/qemu-run"
    ;;
  qemu-audio)
    "$script_dir/qemu-repro-audio"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
