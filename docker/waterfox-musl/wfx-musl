    "$cache_dir/obj-x86_64-alpine-linux-musl-minwayland-release/dist/system_wrappers" \
    "$cache_dir/dist" \
    "$cache_dir/test-rootfs" \
    "$cache_dir/qemu"
}

extra_docker_env_args=()
stage_root_docker_args=()
stage_root_env_args=()

collect_extra_docker_env_args() {
  local name
  extra_docker_env_args=()
  for name in \
    ACTIONS_CACHE_URL \
    ACTIONS_RESULTS_URL \
    ACTIONS_RUNTIME_TOKEN \
    SCCACHE_BUCKET \
    SCCACHE_CACHE_SIZE \
    SCCACHE_ENDPOINT \
    SCCACHE_GHA_ENABLED \
    SCCACHE_GHA_VERSION \
    SCCACHE_IDLE_TIMEOUT \
    SCCACHE_REGION \
    SCCACHE_S3_NO_CREDENTIALS \
    SCCACHE_S3_USE_SSL
  do
    if [ "${!name+x}" = x ]; then
      extra_docker_env_args+=(--env "$name=${!name}")
    fi
  done
}

abs_existing_path() {
  local path=$1
  if [ -d "$path" ]; then
    cd "$path" && pwd -P
  else
    printf '%s/%s\n' "$(cd "$(dirname "$path")" && pwd -P)" "$(basename "$path")"
  fi
}

collect_stage_root_docker_args() {
  local stage_root
  stage_root_docker_args=()
  stage_root_env_args=()
  if [ "${WFX_STAGE_ROOT+x}" != x ]; then
    return
  fi
  stage_root=$WFX_STAGE_ROOT
  if [ -e "$stage_root" ]; then
    stage_root=$(abs_existing_path "$stage_root")
    stage_root_docker_args+=(--volume "$stage_root:/wfx-stage-root:ro")
    stage_root_env_args+=(--env WFX_STAGE_ROOT=/wfx-stage-root)
  else
    stage_root_env_args+=(--env "WFX_STAGE_ROOT=$stage_root")
  fi
}

build_image() {
  DOCKER_BUILDKIT=1 docker build \
    --platform "$platform" \
    --tag "$image" \
    --file "$script_dir/Dockerfile" \
    "$script_dir"
}

run_in_image() {
  local container_mozconfig
  container_mozconfig=${WFX_MOZCONFIG:-$default_mozconfig}
  ensure_cache_dirs
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    build_image
  fi
  collect_extra_docker_env_args
  collect_stage_root_docker_args
  docker run \
    --rm \
    --platform "$platform" \
    --volume "$repo_root:/work" \
    --volume "$cache_dir:/cache" \
    --volume "$cache_dir/build-deps:/opt/wfx/build-deps" \
    --volume "$cache_dir/test-compositor:/opt/wfx/test-compositor" \
    --volume "$cache_dir/kiosk-compositor:/opt/wfx/kiosk-compositor" \
    --volume "$cache_dir/sysroot:/opt/wfx/sysroot" \
    --volume "$cache_dir/apk:/var/cache/apk" \
    "${stage_root_docker_args[@]}" \
    --workdir /work \
    --env MOZCONFIG="$container_mozconfig" \
    --env WFX_SKIP_MACH_OPTIONAL=1 \
    --env DISABLE_TELEMETRY=1 \
    --env WFX_JOBS="${WFX_JOBS:-4}" \
    --env WFX_CARGO_JOBS="${WFX_CARGO_JOBS:-4}" \
    --env WFX_FORCE_REBUILD="${WFX_FORCE_REBUILD:-0}" \
    --env WFX_QEMU_IMAGE_MB="${WFX_QEMU_IMAGE_MB:-2048}" \
    --env WFX_QEMU_INCLUDE_ALPINE_FIREFOX="${WFX_QEMU_INCLUDE_ALPINE_FIREFOX:-0}" \
    --env WFX_QEMU_INCLUDE_WESTON="${WFX_QEMU_INCLUDE_WESTON:-0}" \
    --env WFX_QEMU_INCLUDE_ALSA="${WFX_QEMU_INCLUDE_ALSA:-0}" \
    "${stage_root_env_args[@]}" \
    "${extra_docker_env_args[@]}" \
    "$image" \
    "$@"
}

run_shell() {
  local container_mozconfig
  container_mozconfig=${WFX_MOZCONFIG:-$default_mozconfig}
  ensure_cache_dirs
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    build_image
  fi
  collect_extra_docker_env_args
  collect_stage_root_docker_args
  docker run \
    --rm \
    --interactive \
    --tty \
    --platform "$platform" \
    --volume "$repo_root:/work" \
    --volume "$cache_dir:/cache" \
    --volume "$cache_dir/build-deps:/opt/wfx/build-deps" \
    --volume "$cache_dir/test-compositor:/opt/wfx/test-compositor" \
    --volume "$cache_dir/kiosk-compositor:/opt/wfx/kiosk-compositor" \
    --volume "$cache_dir/sysroot:/opt/wfx/sysroot" \
    --volume "$cache_dir/apk:/var/cache/apk" \
    "${stage_root_docker_args[@]}" \
    --workdir /work \
    --env MOZCONFIG="$container_mozconfig" \
    --env WFX_SKIP_MACH_OPTIONAL=1 \
    --env DISABLE_TELEMETRY=1 \
    --env WFX_JOBS="${WFX_JOBS:-4}" \
    --env WFX_CARGO_JOBS="${WFX_CARGO_JOBS:-4}" \
    --env WFX_FORCE_REBUILD="${WFX_FORCE_REBUILD:-0}" \
    --env WFX_QEMU_IMAGE_MB="${WFX_QEMU_IMAGE_MB:-2048}" \
    --env WFX_QEMU_INCLUDE_ALPINE_FIREFOX="${WFX_QEMU_INCLUDE_ALPINE_FIREFOX:-0}" \
    --env WFX_QEMU_INCLUDE_WESTON="${WFX_QEMU_INCLUDE_WESTON:-0}" \
    --env WFX_QEMU_INCLUDE_ALSA="${WFX_QEMU_INCLUDE_ALSA:-0}" \
    "${stage_root_env_args[@]}" \
    "${extra_docker_env_args[@]}" \
    "$image" \
    bash
}

uses_default_qemu_artifacts() {
  [ -z "${WFX_QEMU_IMAGE+x}" ] &&
    [ -z "${WFX_QEMU_KERNEL+x}" ] &&
    [ -z "${WFX_QEMU_INITRAMFS+x}" ]
}

