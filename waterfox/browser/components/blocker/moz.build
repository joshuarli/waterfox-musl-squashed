XPIDL_SOURCES += [
    "nsIWaterfoxBlocker.idl",
]

XPIDL_MODULE = "waterfox_blocker"

UNIFIED_SOURCES += [
    "WaterfoxBlockerXPCOM.cpp",
]

EXPORTS += [
    "WaterfoxBlockerXPCOM.h",
]

XPCOM_MANIFESTS += [
    "components.conf",
]

JAR_MANIFESTS += [
    "jar.mn",
]

EXTRA_JS_MODULES += [
    "WaterfoxBlockedPage.sys.mjs",
    "WaterfoxBlockedPageChild.sys.mjs",
    "WaterfoxBlockedPageParent.sys.mjs",
    "WaterfoxBlockerChild.sys.mjs",
    "WaterfoxBlockerExtensionDetector.sys.mjs",
    "WaterfoxBlockerPanel.sys.mjs",
    "WaterfoxBlockerParent.sys.mjs",
    "WaterfoxBlockerPreferences.sys.mjs",
    "WaterfoxBlockerService.sys.mjs",
    "WaterfoxBlockerUtils.sys.mjs",
]

EXTRA_JS_MODULES.internal += [
    "internal/EngineCache.sys.mjs",
    "internal/ListCatalog.sys.mjs",
    "internal/ListStore.sys.mjs",
    "internal/ListUpdates.sys.mjs",
    "internal/RemoteResources.sys.mjs",
    "internal/Resources.sys.mjs",
    "internal/SiteExceptions.sys.mjs",
]

LOCAL_INCLUDES += [
    "/toolkit/components/content-classifier/content_classifier_engine",
]

FINAL_LIBRARY = "xul"
